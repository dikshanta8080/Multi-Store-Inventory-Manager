# Copy to .env and fill in values:
#   cp .env.example .env          (Linux/macOS)
#   copy .env.example .env      (Windows)
#
# Local dev: use strong-but-simple passwords only on your machine.
# Production/VPS: use unique secrets (openssl rand -base64 32 for JWT).

# PostgreSQL
POSTGRES_DB=inventory_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# pgAdmin (web UI)
PGADMIN_DEFAULT_EMAIL=admin@yourdomain.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password
PGADMIN_PORT=5050

# Spring Boot app
APP_PORT=8080
IMAGE_TAG=latest

# JWT (generate a random Base64 secret, at least 256 bits)
JWT_SECRET_KEY=change-me-generate-a-secure-base64-secret
JWT_EXPIRATION=86400000
