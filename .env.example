# Copy to .env and fill in values:
#   cp .env.example .env          (Linux/macOS)
#   copy .env.example .env      (Windows)
#
# Local dev: use strong-but-simple passwords only on your machine.
# Production/VPS: use unique secrets (openssl rand -base64 32 for JWT).

# PostgreSQL
POSTGRES_DB=inventory_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_PORT=5432

# pgAdmin (web UI)
PGADMIN_DEFAULT_EMAIL=admin@yourdomain.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password
PGADMIN_PORT=5050

# Spring Boot app
APP_PORT=8080
IMAGE_TAG=latest

# Docker Hub image (pull to run the published app locally or elsewhere)
DOCKER_IMAGE=dikshanta07/inventory-management:latest

# JWT — must match across app restarts (same value as application-dev.yml for local parity)
JWT_SECRET_KEY=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000
